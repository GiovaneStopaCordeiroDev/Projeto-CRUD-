<Window x:Class="Projeto_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projeto_1"
        mc:Ignorable="d"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Ínicio" Height="500" Width="650" >
    <Grid>
        <Button x:Name="btnCadastroMedico" HorizontalAlignment="Left" Margin="264,37,0,0" VerticalAlignment="Top" Height="71" Width="117" Grid.Column="1" Click="btnCadastroMedico_Click">
            <StackPanel Orientation="Vertical" >
                <Image Source="/Imagens Projeto/IconeMedico.png" Width="33"/>
                <TextBlock Text="Cadastrar Médico" FontSize="12"/>
            </StackPanel>
        </Button>
        <Button x:Name="btnCadastroPaciente" HorizontalAlignment="Left" Margin="99,37,0,0" VerticalAlignment="Top" Height="71" Width="119" Grid.Column="1" Click="btnCadastroPaciente_Click" >
            <StackPanel Orientation="Vertical" >
                <Image Source="/Imagens Projeto/IconePaciente.png" Width="30"/>
                <TextBlock Text="Cadastrar Paciente" FontSize="12"/>
            </StackPanel>
        </Button>
        <Button x:Name="btnCadastroConsulta" HorizontalAlignment="Left" Margin="422,37,0,0" VerticalAlignment="Top" Height="71" Width="120" Grid.Column="1" Click="btnCadastroConsulta_Click">
            <StackPanel Orientation="Vertical" >
                <Image Source="/Imagens Projeto/IconeCadastro.png" Width="33"/>
                <TextBlock Text="Cadastrar Consulta" FontSize="12"/>
            </StackPanel>
        </Button>

    </Grid>
</Window>
